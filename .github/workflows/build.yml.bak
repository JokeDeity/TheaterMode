name: Build and Release Windows Executable

on:
  push:
    tags:
      - 'v*' # Triggers the build whenever you push a tag like v1.0, v1.1, etc.

permissions:
  contents: write # Gives GitHub permission to create a release and upload files

jobs:
  build:
    runs-on: windows-latest

    steps:
    - name: Checkout repository code
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install PyQt5 PyQt6 PyQt6-WebEngine pynput pygame pyinstaller pywin32

    - name: Compile with PyInstaller
      run: |
        pyinstaller --noconsole --onefile --icon=icon.ico --add-data "icon.ico;." --add-data "*.mp3;." --add-data "*.wav;." --add-data "*.gif;." dmod.py

    - name: Create GitHub Release
      uses: softprops/action-gh-release@v2
      with:
        files: dist/dmod.exe
        name: Release ${{ github.ref_name }}
        draft: false
        prerelease: false